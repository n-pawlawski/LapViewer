{
  "name": "lapviewer-server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env LAPVIEWER_DEV_USER=1 tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "test": "node --import tsx --test src/**/*.test.ts",
    "test:auth": "tsx scripts/auth-isolation-test.mjs",
    "test:public": "tsx scripts/public-sessions-test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.787.0",
    "@aws-sdk/s3-request-presigner": "^3.787.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.11.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "deasync": "^0.1.30",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lapviewer": "file:..",
    "multer": "^2.2.0",
    "openid-client": "^6.8.4",
    "pg": "^8.14.1",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/deasync": "^0.1.5",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "cross-env": "^10.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
