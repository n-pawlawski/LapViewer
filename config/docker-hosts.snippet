# DeltaView local Docker — side-by-side with npm run dev
#
# Dev (hot reload):  http://localhost:5173  → API on localhost:3000
# Docker (parity):   http://deltaview.docker:3090
#
# Add this line to C:\Windows\System32\drivers\etc\hosts (requires Administrator):
127.0.0.1 deltaview.docker

# Legacy alias (optional):
# 127.0.0.1 lapviewer.docker
