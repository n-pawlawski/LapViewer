# Docker Compose settings — copy to repo-root `.env` (gitignored).
#
# Compose loads `.env` automatically. Object storage (MinIO) is configured in
# docker-compose.yml; override S3_PUBLIC_ENDPOINT here if 127.0.0.1 is wrong for your host.

# Browser-reachable MinIO endpoint for presigned upload URLs (default in compose)
# S3_PUBLIC_ENDPOINT=http://127.0.0.1:9000
