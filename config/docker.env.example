# Docker Compose settings — copy to repo-root `.env` (gitignored).
#
# Compose loads `.env` automatically for ${VIDEO_HOST_PATH} in docker-compose.yml.
# Use forward slashes for Windows paths.

# Host folder mounted read-only at /videos inside the container
VIDEO_HOST_PATH=E:/Racing Videos

# Optional: override demo clip path inside the container
# DEMO_VIDEO_PATH=/videos/2-19 racing league/GX010012.MP4
