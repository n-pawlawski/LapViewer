# LapViewer environment (copy to .env at repo root or set in deployment)

# --- Runtime ---
PORT=3000
DEPLOY_ENV=development
# production | staging | development | local-docker
NODE_ENV=development

# Injected at Docker build / CI deploy
GIT_SHA=local

# --- Security ---
SESSION_SECRET=change-me-in-production
CLIENT_ORIGIN=http://localhost:5173

# Google OAuth (production sign-in)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Optional override (default: CLIENT_ORIGIN + /api/auth/google/callback)
# GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/google/callback

# --- Storage ---
# Upload works out of the box via POST /api/sessions/upload (direct server upload).
# Files land in DATA_DIR/objects/ locally, or S3/MinIO when STORAGE_BACKEND=s3.
STORAGE_BACKEND=local_path
DATA_DIR=./data

# Optional: S3 / MinIO for production-parity object storage
# STORAGE_BACKEND=s3
# S3_BUCKET=lapviewer-videos
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_ENDPOINT_URL=http://127.0.0.1:9000
# S3_PUBLIC_ENDPOINT=http://127.0.0.1:9000
# S3_FORCE_PATH_STYLE=true

# Legacy path intake (deprecated — existing sessions only)
# VIDEO_LIBRARY_ROOT=E:\Racing Videos

# --- Database ---
# Omit for SQLite (local default). Set for RDS Postgres in production.
# DATABASE_URL=postgres://user:pass@host:5432/lapviewer

# --- Dev only ---
LAPVIEWER_DEV_USER=1
